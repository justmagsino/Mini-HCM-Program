rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP: all business data via Express + Admin SDK only (client SDK denied).
    match /users/{userId} {
      allow read, write: if false;
    }
    match /attendance/{docId} {
      allow read, write: if false;
    }
    match /dailySummary/{docId} {
      allow read, write: if false;
    }

    // Deny any other collection (Firebase best practice).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
