# Production server — set in Render/Vercel dashboard (do not commit)
# For local production smoke test: copy to server/.env and set NODE_ENV=production

NODE_ENV=production
PORT=3001
TRUST_PROXY=true

# Comma-separated browser origins allowed by CORS
# Example: https://your-app.web.app,https://your-app.firebaseapp.com
CORS_ORIGIN=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste key with literal \n between lines, or use host multiline secret
FIREBASE_PRIVATE_KEY=

DEFAULT_TIMEZONE=Asia/Manila
DEFAULT_SHIFT_START=09:00
DEFAULT_SHIFT_END=18:00
ALLOW_PUBLIC_REGISTER=false
LATE_ALERT_MINUTES=15
UNDERTIME_ALERT_MINUTES=30
