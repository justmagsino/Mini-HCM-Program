# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated browser origins (dev + production Hosting URLs)
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false

# Firebase Admin SDK — service account (Project settings → Service accounts → Generate key)
# Copy private_key from the JSON exactly (one line, double-quoted, with \n escapes):
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Organization defaults (used when creating users)
DEFAULT_TIMEZONE=Asia/Manila
DEFAULT_SHIFT_START=09:00
DEFAULT_SHIFT_END=18:00

# Registration — set true only for open self-signup in dev
ALLOW_PUBLIC_REGISTER=false

# Optional server defaults (employee tardiness tags use client VITE_* vars)
LATE_ALERT_MINUTES=15
UNDERTIME_ALERT_MINUTES=30

# Password applied by admin "Reset password" on Employees page (default: password)
ADMIN_RESET_PASSWORD=password
