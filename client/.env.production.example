# Production build — copy to client/.env.production (never commit)
# Used by: npm run build:prod / root npm run build:client

# Firebase Web App (public config — safe in the static bundle)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Express API origin (HTTPS, no trailing slash, no /api suffix)
# Render: https://mini-hcm-api.onrender.com
# Vercel: https://your-project.vercel.app
VITE_API_BASE_URL=
