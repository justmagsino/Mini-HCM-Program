# Firebase Web App (public — safe in client bundle)
# From Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Express API origin (no trailing /api — the client appends /api automatically)
VITE_API_BASE_URL=http://localhost:3001

# Optional — late/undertime badge thresholds on employee attendance history
# VITE_LATE_ALERT_MINUTES=15
# VITE_UNDERTIME_ALERT_MINUTES=30
